<?xml version="1.0" encoding="utf-8"?>
    <resources>
        <style name="CalculatorButton">
            <item name="android:layout_width">0dp</item>
            <item name="android:layout_height">match_parent</item>
            <item name="android:layout_weight">1</item>
            <item name="android:layout_margin">4dp</item>
            <item name="android:textSize">24sp</item>
        </style>

        <style name="NumberButton" parent="CalculatorButton">
            <item name="android:backgroundTint">@color/sky_blue_light</item>
            <item name="android:textColor">@color/display_text</item>
        </style>

        <style name="OperatorButton" parent="CalculatorButton">
            <item name="android:backgroundTint">@color/operator_blue</item>
            <item name="android:textColor">@color/white</item>
        </style>

        <style name="EqualButton" parent="CalculatorButton">
            <item name="android:backgroundTint">@color/equal_blue</item>
            <item name="android:textColor">@color/white</item>
        </style>

        <style name="ClearButton" parent="CalculatorButton">
            <item name="android:backgroundTint">@color/error_red</item>
            <item name="android:textColor">@color/white</item>
        </style>
    </resources>